# =============================================================
# 不动产抵质押品核对应答系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# =============================================================

# ---------- 数据库配置 ----------
# PostgreSQL 连接串（私有化部署必填）
DATABASE_URL=postgresql://collateral:changeme_strong_password@postgres:5432/collateral

# 是否启用 SSL（内网部署通常为 false）
DB_SSL=false

# ---------- Docker Compose 数据库配置 ----------
POSTGRES_DB=collateral
POSTGRES_USER=collateral
POSTGRES_PASSWORD=changeme_strong_password

# ---------- 应用配置 ----------
NODE_ENV=production
PORT=3000

# ---------- SSO 配置（行内统一认证，待对接） ----------
# SSO 登录地址
# SSO_LOGIN_URL=https://sso.your-bank.gov.cn/login
# SSO 登出地址
# SSO_LOGOUT_URL=https://sso.your-bank.gov.cn/logout
# SSO 回调地址
# SSO_CALLBACK_URL=https://your-domain.gov.cn/api/auth/callback
# SSO Client ID
# SSO_CLIENT_ID=your-client-id
# SSO Client Secret
# SSO_CLIENT_SECRET=your-client-secret

# ---------- 省局数据接口（待对接） ----------
# PROVINCIAL_API_URL=https://api.provincial-bureau.gov.cn
# PROVINCIAL_API_KEY=your-api-key
# PROVINCIAL_API_TIMEOUT=30000
